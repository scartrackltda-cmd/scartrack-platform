# ══════════════════════════════════════════════════════════════
# Scartrack Platform — Environment Variables
# ══════════════════════════════════════════════════════════════
# 1. Copie este arquivo:  cp .env.example .env
# 2. Preencha todos os valores marcados com <CHANGE_ME>
# 3. Para rodar em produção: docker compose up --build -d
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=scartrack
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=scartrackdb

# ── Prisma / App Database URL ──────────────────────────────────
# (em Docker: host = "db"; em dev local: host = "localhost")
DATABASE_URL="postgresql://scartrack:<CHANGE_ME>@db:5432/scartrackdb?schema=public"

# ── NextAuth ───────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=<CHANGE_ME_MIN_32_CHARS>
NEXTAUTH_URL=http://localhost:3000
# Em produção com domínio:
# NEXTAUTH_URL=https://scartrack.seudominio.com.br

# ── Mapbox GL JS ───────────────────────────────────────────────
# Obtenha em: https://account.mapbox.com/access-tokens/
# IMPORTANTE: necessário em tempo de BUILD (baked no bundle)
NEXT_PUBLIC_MAPBOX_TOKEN=<SEU_TOKEN_MAPBOX_AQUI>

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Scartrack Platform"
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Em produção:
# NEXT_PUBLIC_APP_URL=https://scartrack.seudominio.com.br

# ── Socket.io ──────────────────────────────────────────────────
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ── Node ───────────────────────────────────────────────────────
NODE_ENV=production
