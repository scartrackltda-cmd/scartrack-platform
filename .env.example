# ============================================
# Scartrack Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- Database ---
DATABASE_URL="postgresql://scartrack:scartrack123@localhost:5432/scartrackdb?schema=public"
POSTGRES_USER=scartrack
POSTGRES_PASSWORD=scartrack123
POSTGRES_DB=scartrackdb

# --- NextAuth ---
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-change-me"
NEXTAUTH_URL="http://localhost:3000"

# --- Mapbox ---
# Get your token at: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN="YOUR_MAPBOX_TOKEN_HERE"

# --- Socket.io ---
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Scartrack Platform"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
