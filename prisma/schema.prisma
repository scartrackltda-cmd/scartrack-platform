// Scartrack Platform - Prisma Schema with PostGIS support
// https://www.prisma.io/docs/concepts/components/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuid_ossp(map: "uuid-ossp")]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  IDLE
  MOVING
  ALERT
}

enum VehicleType {
  CAR
  TRUCK
  MOTORCYCLE
  VAN
  BUS
  BOAT
  OTHER
}

enum AlertType {
  SPEEDING
  GEOFENCE_ENTER
  GEOFENCE_EXIT
  BATTERY_LOW
  CONNECTION_LOST
  SOS
  TAMPERING
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(OPERATOR)
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicles   Vehicle[]
  alerts     Alert[]
  geofences  Geofence[]

  @@map("users")
}

model Device {
  id           String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  imei         String       @unique
  name         String
  model        String?
  simCard      String?      @map("sim_card")
  status       DeviceStatus @default(OFFLINE)
  lastSeenAt   DateTime?    @map("last_seen_at")
  firmwareVer  String?      @map("firmware_ver")
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  vehicle   Vehicle?
  locations Location[]

  @@map("devices")
}

model Vehicle {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  plate        String      @unique
  alias        String?
  type         VehicleType @default(CAR)
  brand        String?
  model        String?
  year         Int?
  color        String?
  odometer     Float?      @default(0)
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  owner    User?   @relation(fields: [ownerId], references: [id])
  ownerId  String? @db.Uuid @map("owner_id")
  device   Device? @relation(fields: [deviceId], references: [id])
  deviceId String? @unique @db.Uuid @map("device_id")

  locations Location[]
  alerts    Alert[]

  @@map("vehicles")
}

model Location {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  // PostGIS geometry point (longitude, latitude)
  longitude Float
  latitude  Float
  altitude  Float?
  speed     Float?   @default(0)   // km/h
  heading   Float?   @default(0)   // degrees 0-360
  accuracy  Float?
  satellites Int?
  ignition  Boolean  @default(false)
  rawData   Json?    @map("raw_data")
  createdAt DateTime @default(now()) @map("created_at")

  device    Device  @relation(fields: [deviceId], references: [id])
  deviceId  String  @db.Uuid @map("device_id")
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  vehicleId String?  @db.Uuid @map("vehicle_id")

  @@index([deviceId, createdAt(sort: Desc)])
  @@index([vehicleId, createdAt(sort: Desc)])
  @@map("locations")
}

model Geofence {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  description String?
  // Polygon coordinates stored as JSON array of [lng, lat] pairs
  coordinates Json
  color       String   @default("#3B82F6")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String @db.Uuid @map("created_by_id")

  alerts Alert[]

  @@map("geofences")
}

model Alert {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type        AlertType
  message     String
  longitude   Float?
  latitude    Float?
  speed       Float?
  read        Boolean   @default(false)
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  vehicleId  String   @db.Uuid @map("vehicle_id")
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?  @db.Uuid @map("user_id")
  geofence   Geofence? @relation(fields: [geofenceId], references: [id])
  geofenceId String?  @db.Uuid @map("geofence_id")

  @@index([vehicleId, createdAt(sort: Desc)])
  @@index([read, createdAt(sort: Desc)])
  @@map("alerts")
}
